{
  "name": "lean-launcher",
  "version": "1.0.0",
  "description": "Lean Launcher - Custom Minecraft Launcher",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "electron": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "build:dir": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": "Lyam",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.lyam.leanlauncher",
    "productName": "Lean Launcher",
    "directories": {
      "output": "dist"
    },
    "icon": "icon.png",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "index.js",
      "index.html",
      "ui.js",
      "style.css",
      "package.json",
      "changelog.json",
      "icon.png",
      "lib/**/*",
      "mod-profiles/**/*"
    ],
    "extraResources": [
      {
        "from": "mod-profiles",
        "to": "mod-profiles"
      },
      {
        "from": "icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "publish": {
        "provider": "github"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "icon": "icon.png",
      "target": [
        {
          "target": "dmg"
        },
        {
          "target": "zip"
        }
      ],
      "category": "public.app-category.games",
      "identity": null,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "publish": {
        "provider": "github"
      }
    },
    "linux": {
      "icon": "icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Game",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "publish": {
        "provider": "github"
      }
    }
  }
}
